# Copia questo file in `.env.local` e riempi i valori del tuo progetto Supabase.
# Senza queste variabili l'app resta in modalita' solo-locale (localStorage), senza errori.

# --- Frontend (esposte al client, prefisso VITE_) ---
# Dashboard Supabase -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Importer esercizi (solo lato server, NON esporre al client) ---
# Usato da `npm run import:exercises`. La service role key ha privilegi pieni:
# tienila fuori dal frontend e fuori dal repo (.env.local e' gia' in .gitignore).
SUPABASE_SERVICE_ROLE_KEY=

# Opzionali: sorgente dati dell'importer (default: Free Exercise DB)
# EXERCISE_IMPORT_SOURCE_KEY=free_exercise_db
# EXERCISE_IMPORT_SOURCE_NAME=Free Exercise DB
